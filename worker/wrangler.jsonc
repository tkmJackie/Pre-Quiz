{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cct-english-api",
  "main": "src/index.js",
  "compatibility_date": "2026-06-01",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "cct_english_db",
      "database_id": "REPLACE_WITH_YOUR_D1_DATABASE_ID"
    }
  ],
  "vars": {
    "CORS_ORIGIN": "*"
  }
}
